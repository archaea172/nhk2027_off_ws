<?xml version="1.0" ?>
<robot name="ide_arm_macro" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find sim_pkg)/urdf/ide_arm.trans" />

<xacro:macro name="ide_arm" params="prefix:=''">
  <link name="arm_base"/>

  <link name="link_1_v2_1">
    <inertial>
      <origin xyz="0.017436936078169506 0.19863903889518106 -0.005800117560290835" rpy="0 0 0"/>
      <mass value="3.5325291043519966"/>
      <inertia ixx="0.193016" iyy="0.011365" izz="0.184162" ixy="-0.001521" iyz="-0.002565" ixz="-0.000119"/>
    </inertial>
    <visual>
      <origin xyz="0.005751 -0.088 -0.13" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://sim_pkg/models/meshes/link_1_v2_1.stl" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="aluminum_satin"/>
    </visual>
    <collision>
      <origin xyz="0.005751 -0.088 -0.13" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://sim_pkg/models/meshes/link_1_v2_1.stl" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
  </link>

  <link name="link_2_v1_1">
    <inertial>
      <origin xyz="-0.023583323602407703 0.0881743103170528 0.04123693865974003" rpy="0 0 0"/>
      <mass value="1.5772939629978953"/>
      <inertia ixx="0.043814" iyy="0.000956" izz="0.043605" ixy="0.002284" iyz="-0.001987" ixz="0.000231"/>
    </inertial>
    <visual>
      <origin xyz="-0.021249 -0.527289 -0.090178" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://sim_pkg/models/meshes/link_2_v1_1.stl" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="aluminum_satin"/>
    </visual>
    <collision>
      <origin xyz="-0.021249 -0.527289 -0.090178" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://sim_pkg/models/meshes/link_2_v1_1.stl" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
  </link>

  <link name="end_effector_v1_1">
    <inertial>
      <origin xyz="-0.07222853245081884 0.1407827459051364 4.278768657439702e-07" rpy="0 0 0"/>
      <mass value="0.32794468549770983"/>
      <inertia ixx="0.003366" iyy="0.00235" izz="0.005662" ixy="0.001697" iyz="-0.0" ixz="-0.0"/>
    </inertial>
    <visual>
      <origin xyz="-0.02 -0.02 -0.005" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://sim_pkg/models/meshes/end_effector_v5.stl" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="aluminum_satin"/>
    </visual>
    <collision>
      <origin xyz="-0.02 -0.02 -0.005" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://sim_pkg/models/meshes/end_effector_v5.stl" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
  </link>

  <link name="arm_base_v2_1">
    <inertial>
      <origin xyz="-0.002721948795508748 0.09113126713684143 0.11794174723065468" rpy="0 0 0"/>
      <mass value="5.012895745680244"/>
      <inertia ixx="0.024327" iyy="0.014645" izz="0.015421" ixy="-0.000185" iyz="0.001647" ixz="0.000104"/>
    </inertial>
    <visual>
      <origin xyz="-0.0 -0.0 -0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://sim_pkg/models/meshes/arm_base_v2_1.stl" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="aluminum_satin"/>
    </visual>
    <collision>
      <origin xyz="-0.0 -0.0 -0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://sim_pkg/models/meshes/arm_base_v2_1.stl" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
  </link>

  <link name="tcp_link"/>

  <joint name="fix" type="fixed">
    <parent link="arm_base"/>
    <child link="arm_base_v2_1"/>
  </joint>

  <joint name="joint1" type="revolute">
    <origin xyz="-0.005751 0.088 0.13" rpy="0 0 0"/>
    <parent link="arm_base_v2_1"/>
    <child link="link_1_v2_1"/>
    <axis xyz="1.0 0.0 0.0"/>
    <limit upper="3.141593" lower="0" effort="1000000" velocity="100"/>
    <dynamics damping="30.0" friction="0.2"/>
  </joint>

  <joint name="joint2" type="prismatic">
    <origin xyz="0.027 0.439289 -0.039822" rpy="0 0 0"/>
    <parent link="link_1_v2_1"/>
    <child link="link_2_v1_1"/>
    <axis xyz="-0.0 1.0 0.0"/>
    <limit upper="0.302" lower="0.0" effort="1000000" velocity="100"/>
    <dynamics damping="80.0" friction="0.2"/>
  </joint>

  <joint name="joint3" type="revolute">
    <origin xyz="-0.054 0.1955 0.0572" rpy="3.141593 0 0"/>
    <parent link="link_2_v1_1"/>
    <child link="end_effector_v1_1"/>
    <axis xyz="1.0 0.0 0.0"/>
    <limit upper="3.5" lower="-1.57" effort="1000000" velocity="100"/>
    <dynamics damping="30.0" friction="0.2"/>
  </joint>

  <joint name="end_effector" type="fixed">
    <origin xyz="-0.15 0.150 0" rpy="0 0 0"/>
    <parent link="end_effector_v1_1"/>
    <child link="tcp_link"/>
  </joint>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher" />
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint1</joint_name>
      <joint_index>0</joint_index>
      <topic>/joint_sim1</topic>
      <p_gain>900.0</p_gain>
      <i_gain>25.0</i_gain>
      <d_gain>48.0</d_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint2</joint_name>
      <joint_index>0</joint_index>
      <topic>/joint_sim2</topic>
      <p_gain>900.0</p_gain>
      <i_gain>25.0</i_gain>
      <d_gain>140.0</d_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>joint3</joint_name>
      <joint_index>0</joint_index>
      <topic>/joint_sim3</topic>
      <p_gain>900.0</p_gain>
      <i_gain>25.0</i_gain>
      <d_gain>48.0</d_gain>
    </plugin>
  </gazebo>
</xacro:macro>

</robot>
